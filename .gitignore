*.csv

# Python cache
__pycache__/
*.pyc
*.pyo

# Jupyter checkpoints
.ipynb_checkpoints/

# Virtual environments
.venv/
venv/
env/

# System files
.DS_Store
Thumbs.db

# Logs and temporary files
*.log
*.tmp

